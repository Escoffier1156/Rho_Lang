{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ρ (RHO)",
  "scopeName": "source.rho",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#symbols"
    },
    {
      "include": "#ext_binding"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.rho",
          "match": "//.*$"
        },
        {
          "name": "comment.block.rho",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "symbols": {
      "patterns": [
        {
          "name": "keyword.operator.rho.space",
          "match": "[◯□]"
        },
        {
          "name": "keyword.operator.rho.shift",
          "match": "[▷▽]"
        },
        {
          "name": "keyword.operator.rho.flow",
          "match": "[→=]"
        },
        {
          "name": "keyword.operator.rho.meta",
          "match": "[!$&]"
        },
        {
          "name": "keyword.operator.rho.arithmetic",
          "match": "[+\\-×*/^]"
        },
        {
          "name": "keyword.operator.rho.comparison",
          "match": "[<>]|>=|<="
        }
      ]
    },
    "ext_binding": {
      "patterns": [
        {
          "name": "constant.numeric.hex.rho",
          "match": "0x[0-9a-fA-F]+"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.rho",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.rho",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b|[△𝜏τ]"
        }
      ]
    }
  }
}
